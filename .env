# Server
PORT=5001

# Admin credentials
ADMIN_PHONE=9744226927
ADMIN_PASSWORD=Naresh@5454

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# EMAIL — Brevo SMTP (FREE — 300 emails/day, RECOMMENDED)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Setup (2 minutes):
# 1. Go to https://app.brevo.com/  → Sign up free (no credit card)
# 2. Go to Settings → SMTP & API → SMTP
# 3. Copy "Login" (your signup email) → paste as BREVO_USER
# 4. Copy "SMTP Key" (looks like xsmtpsib-xxxxx...) → paste as BREVO_PASS
# 5. Set BREVO_FROM to the email you signed up with

EMAIL_PROVIDER=brevo
BREVO_USER=your-brevo-login-email@gmail.com
BREVO_PASS=xsmtpsib-paste-your-smtp-key-here
BREVO_FROM=your-brevo-login-email@gmail.com

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ALTERNATIVE 1: Gmail SMTP (needs App Password)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# To use Gmail instead, change EMAIL_PROVIDER to gmail
# and fill in GMAIL_USER + GMAIL_APP_PASSWORD:
# EMAIL_PROVIDER=gmail
# GMAIL_USER=your-email@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ALTERNATIVE 2: Resend API
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# RESEND_API_KEY=
# RESEND_FROM=Birgunj Fashion <onboarding@resend.dev>

# Cloudflare Worker JWT secret (must match Worker if using one)
WORKER_JWT_SECRET=birgunj-fashion-change-this-to-a-random-secret
